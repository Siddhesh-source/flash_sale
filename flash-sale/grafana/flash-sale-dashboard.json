{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "schemaVersion": 39,
  "title": "Flash Sale — Observability",
  "uid": "flashsale-v1",
  "tags": ["flash-sale", "slo"],
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Reservation Rate by Result (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (result) (rate(reservation_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "sold_out" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error" },    "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "success" },  "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 2,
      "title": "Reservation Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slo:reserve_p50_latency:5m * 1000", "legendFormat": "p50 (ms)" },
        { "expr": "slo:reserve_p95_latency:5m * 1000", "legendFormat": "p95 (ms)" },
        { "expr": "slo:reserve_p99_latency:5m * 1000", "legendFormat": "p99 (ms)" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99 (ms)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 100 }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Available Stock per Sale",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "stock_available", "legendFormat": "sale {{sale_id}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } }
    },
    {
      "id": 4,
      "title": "Waitlist Depth per Sale",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "waitlist_depth", "legendFormat": "sale {{sale_id}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } }
    },
    {
      "id": 5,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "websocket_connections_active", "legendFormat": "connections" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red",    "value": 5000 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "SLO 1 — Availability Error Budget Burn Rate",
      "description": "1.0 = burning at the exact allowed rate. >1 = over-budget. >14.4 = critical (1h budget gone in 5m).",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slo:reserve_error_budget_burn_rate:5m", "legendFormat": "burn rate (5m)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 6 },
              { "color": "red",    "value": 14.4 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "SLO 2 — Latency Error Budget Burn Rate",
      "description": "1.0 = consuming error budget at the allowed rate. >14.4 = critical.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "slo:reserve_latency_burn_rate:5m", "legendFormat": "burn rate (5m)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 6 },
              { "color": "red",    "value": 14.4 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "SLO 3 — Reconciliation Corrections (Correctness)",
      "description": "Any non-zero value indicates a potential oversell or Redis/Postgres drift. Target: always zero.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "increase(reconciliation_corrections_total[5m])", "legendFormat": "corrections / 5m" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 0.001 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Rate-Limited Requests by User",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(rate_limited_total[1m]))", "legendFormat": "total rate-limited (req/s)" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
